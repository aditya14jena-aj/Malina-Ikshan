# Environment (development, staging, production)
ENV=development

# Secret Key for JWT Signing
SECRET_KEY=devsecretkeychangeinproduction

# Database Connection URL
DATABASE_URL=sqlite:///./malina.db

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated list, e.g., http://localhost:5173,http://127.0.0.1:5173)
CORS_ORIGINS=*
